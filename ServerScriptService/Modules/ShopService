local RepS = game:GetService("ReplicatedStorage")
local HttpS = game:GetService("HttpService")
local Players = game:GetService("Players")
local ServerScriptS = game:GetService("ServerScriptService")

local shared = RepS.Shared
local modules = shared.Modules

local ShopConfig = require(modules.ShopConfig)
local DatabaseService = require(script.Parent:WaitForChild("DatabaseService"))

type CrateRegistryEntry = {
	ToolInstance: Tool,
	Style: string,
	Rarity: string,
	Settings: any,
}

type ActiveStockItem = {
	Name: string,
	Stock: number,
	Price: number,
	Rarity: string,
	Style: string,
}

local ShopService = {
	Registry = {} :: { [string]: CrateRegistryEntry },
	AvailableThemes = {} :: { string },

	ThemeRarityMap = {} :: { [string]: { [string]: { string } } },

	CurrentStock = {} :: { [string]: ActiveStockItem },
	CurrentToken = "" :: string,
	ExpirationTime = 0 :: number,

	_Initialized = false,
}

local function GetRemote(name: string, className: "RemoteEvent" | "UnreliableRemoteEvent"): any
	local eventsFolder = RepS:FindFirstChild("Events")
	if not eventsFolder then
		local newFolder = Instance.new("Folder")
		newFolder.Name = "Events"
		newFolder.Parent = RepS
		eventsFolder = newFolder
	end

	local remotesFolder = eventsFolder:FindFirstChild("Remotes")
	if not remotesFolder then
		local newFolder = Instance.new("Folder")
		newFolder.Name = "Remotes"
		newFolder.Parent = eventsFolder
		remotesFolder = newFolder
	end

	local targetRemote = remotesFolder:FindFirstChild(name)
	if not targetRemote then
		local newRemote = Instance.new(className)
		newRemote.Name = name
		newRemote.Parent = remotesFolder
		targetRemote = newRemote
	end

	return targetRemote
end

local function BroadcastStockUpdate()
	local compressedPayload = {
		Expiration = ShopService.ExpirationTime,
		Token = ShopService.CurrentToken,
		Stock = {} :: { [string]: { Stock: number, Price: number, Rarity: string, Style: string } }
	}

	for crateName, details in pairs(ShopService.CurrentStock) do
		compressedPayload.Stock[crateName] = {
			Stock = details.Stock,
			Price = details.Price,
			Rarity = details.Rarity,
			Style = details.Style,
		}
	end

	local stockUpdatedRemote = GetRemote("ShopStockUpdated", "RemoteEvent") :: RemoteEvent
	stockUpdatedRemote:FireAllClients(compressedPayload)
end

function ShopService.GetCrateData(crateName: string): CrateRegistryEntry?
	return ShopService.Registry[crateName]
end

function ShopService.Initialize()
	local cratesFolder: Folder? = RepS.Shared:FindFirstChild("Crates") :: Folder?
	if not cratesFolder then
		error("[ShopService]: Critical error - 'Crates' directory could not be located in ReplicatedStorage!")
		return
	end

	table.clear(ShopService.Registry)
	table.clear(ShopService.AvailableThemes)
	table.clear(ShopService.ThemeRarityMap)

	for _, themeFolder in ipairs(cratesFolder:GetChildren()) do
		if not themeFolder:IsA("Folder") then continue end

		local themeName: string = themeFolder.Name
		if not table.find(ShopService.AvailableThemes, themeName) then
			table.insert(ShopService.AvailableThemes, themeName)
		end

		ShopService.ThemeRarityMap[themeName] = {
			Common = {},
			Uncommon = {},
			Rare = {},
			Epic = {},
			Legendary = {},
		}

		for _, toolAsset in ipairs(themeFolder:GetChildren()) do
			if not toolAsset:IsA("Tool") then continue end

			local parsedData = ShopConfig.ParseCrateName(toolAsset.Name)
			if parsedData then
				local rarityConfig = ShopConfig.Rarities[parsedData.Rarity]

				ShopService.Registry[parsedData.Name] = {
					ToolInstance = toolAsset,
					Style = parsedData.Style,
					Rarity = parsedData.Rarity,
					Settings = rarityConfig,
				}

				table.insert(ShopService.ThemeRarityMap[themeName][parsedData.Rarity], parsedData.Name)
			end
		end
	end

	ShopService._Initialized = true

	ShopService.UpdateMarketStock()
	ShopService.StartStockLoop()
	ShopService.ConnectNetworkHandlers()
end

function ShopService.UpdateMarketStock()
	if not ShopService._Initialized then return end

	table.clear(ShopService.CurrentStock)

	local slotLimit: number = ShopConfig.MAX_SHOP_SLOTS
	local stockToken: string = HttpS:GenerateGUID(false)

	local now: number = workspace:GetServerTimeNow()
	local nextExpiration: number = now + (300 - (now % 300))

	for slotIndex = 1, slotLimit do
		if #ShopService.AvailableThemes == 0 then break end

		local rolledTheme: string = ShopService.AvailableThemes[math.random(1, #ShopService.AvailableThemes)]

		local rarityRoll: number = math.random(1, 100)
		local selectedRarity: string = "Common"
		local cumulativeWeight = 0

		for rarityName, rarityInfo in pairs(ShopConfig.Rarities) do
			cumulativeWeight += rarityInfo.Weight
			if rarityRoll <= cumulativeWeight then
				selectedRarity = rarityName
				break
			end
		end

		local availableTools: { string } = ShopService.ThemeRarityMap[rolledTheme][selectedRarity]

		if #availableTools == 0 then
			for _, fallbackRarity in ipairs({"Common", "Uncommon", "Rare", "Epic", "Legendary"}) do
				if #ShopService.ThemeRarityMap[rolledTheme][fallbackRarity] > 0 then
					availableTools = ShopService.ThemeRarityMap[rolledTheme][fallbackRarity]
					selectedRarity = fallbackRarity
					break
				end
			end
		end

		if #availableTools == 0 then
			local keys = {}
			for key, val in pairs(ShopService.Registry) do
				if val.Style == rolledTheme then
					table.insert(keys, key)
				end
			end
			availableTools = keys
		end

		if #availableTools > 0 then
			local selectedCrateName: string = availableTools[math.random(1, #availableTools)]
			local registryData = ShopService.Registry[selectedCrateName]
			local raritySettings = registryData.Settings

			local stockCapacity: number = math.random(raritySettings.MinStock, raritySettings.MaxStock)
			local itemCost: number = raritySettings.BaseCost

			if not ShopService.CurrentStock[selectedCrateName] then
				ShopService.CurrentStock[selectedCrateName] = {
					Name = selectedCrateName,
					Stock = stockCapacity,
					Price = itemCost,
					Rarity = selectedRarity,
					Style = rolledTheme,
				}
			else
				ShopService.CurrentStock[selectedCrateName].Stock += stockCapacity
			end
		end
	end

	ShopService.CurrentToken = stockToken
	ShopService.ExpirationTime = nextExpiration

	BroadcastStockUpdate()
end

function ShopService.StartStockLoop()
	task.spawn(function()
		local lastInterval = math.floor(workspace:GetServerTimeNow() / 300)

		while true do
			task.wait(1)
			local currentInterval = math.floor(workspace:GetServerTimeNow() / 300)

			if currentInterval ~= lastInterval then
				lastInterval = currentInterval
				local success, err = pcall(function()
					ShopService.UpdateMarketStock()
				end)
				if not success then
					warn(`[ShopService]: Error encountered during automatic restock roll: {err}`)
				end
			end
		end
	end)

	Players.PlayerAdded:Connect(function(player)
		if ShopService.CurrentToken ~= "" then
			task.spawn(function()
				task.wait(2)

				local compressedPayload = {
					Expiration = ShopService.ExpirationTime,
					Token = ShopService.CurrentToken,
					Stock = {} :: { [string]: { Stock: number, Price: number, Rarity: string, Style: string } }
				}

				for crateName, details in pairs(ShopService.CurrentStock) do
					compressedPayload.Stock[crateName] = {
						Stock = details.Stock,
						Price = details.Price,
						Rarity = details.Rarity,
						Style = details.Style,
					}
				end

				local stockUpdatedRemote = GetRemote("ShopStockUpdated", "RemoteEvent") :: RemoteEvent
				stockUpdatedRemote:FireClient(player, compressedPayload)
			end)
		end
	end)
end

-- Connecting and securing checkout remote interactions
function ShopService.ConnectNetworkHandlers()
	local purchaseRequest = GetRemote("PurchaseRequest", "RemoteEvent") :: RemoteEvent
	local purchaseResponse = GetRemote("PurchaseResponse", "RemoteEvent") :: RemoteEvent

	purchaseRequest.OnServerEvent:Connect(function(player: Player, requestedCrate: any)
		if typeof(requestedCrate) ~= "string" then
			warn(`[ShopService Security]: Rejected malformed checkout request from {player.Name}`)
			purchaseResponse:FireClient(player, false, "Invalid request payload.")
			return
		end

		local character = player.Character
		local hrp = character and character:FindFirstChild("HumanoidRootPart") :: BasePart?

		if not hrp then
			purchaseResponse:FireClient(player, false, "Character state unresolved.")
			return
		end

		local shopCounter = workspace:FindFirstChild("ShopCounter") or workspace:FindFirstChild("Register")
		if shopCounter and shopCounter:IsA("BasePart") then
			local distance = (hrp.Position - shopCounter.Position).Magnitude
			if distance > 25 then
				warn(`[ShopService Security]: Detected suspicious checkout transaction! {player.Name} was {math.round(distance)} studs away from the counter. Transaction blocked.`)
				purchaseResponse:FireClient(player, false, "Too far away from the cash register.")
				return
			end
		end

		local stockDetails = ShopService.CurrentStock[requestedCrate]
		if not stockDetails then
			purchaseResponse:FireClient(player, false, "Item is not currently in stock.")
			return
		end

		if stockDetails.Stock <= 0 then
			purchaseResponse:FireClient(player, false, "Item sold out!")
			return
		end

		local registryData = ShopService.Registry[requestedCrate]
		if not registryData then
			purchaseResponse:FireClient(player, false, "Crate asset registration mismatch.")
			return
		end

		-- ====================================================================
		-- AUTHORITATIVE DATABASE INTEGRATION: SECURE WALLET DEDUCTION
		-- ====================================================================
		-- Check and adjust player coins authoritatively through safe server mutators
		local price = stockDetails.Price
		local purchaseSuccess = DatabaseService.AdjustCoins(player, -price)

		if not purchaseSuccess then
			purchaseResponse:FireClient(player, false, "Insufficient funds in your account!")
			return
		end

		-- Mutate physical stock count
		stockDetails.Stock -= 1

		-- Provision backpack tool securely
		local backpack = player:FindFirstChildOfClass("Backpack")
		if backpack then
			local toolClone = registryData.ToolInstance:Clone()
			toolClone.CanBeDropped = false
			toolClone.Parent = backpack

			print(`[ShopService]: {player.Name} spent {price} coins and unlocked {requestedCrate}.`)
		else
			-- Transaction refund fallback if backpack was destroyed mid-route
			DatabaseService.AdjustCoins(player, price)
			purchaseResponse:FireClient(player, false, "Backpack inventory could not be resolved. Refunded.")
			return
		end

		purchaseResponse:FireClient(player, true)
		BroadcastStockUpdate()
	end)
end

return ShopService
