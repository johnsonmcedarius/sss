--[[
	Deeply copies an arbitrary data table to isolate state manipulation sandboxes.
]]
local function DeepCopyTable(original: any): any
	if typeof(original) ~= "table" then return original end
	local copy = {}
	for k, v in pairs(original) do
		copy[k] = DeepCopyTable(v)
	end
	return copy
end

-- ============================================================================
-- INTERMEDIATE MATHEMATICAL CFRAME SERIALIZATION (JSON-COMPATIBLE LAYOUT)
-- ============================================================================

--[[
	Converts a Roblox CFrame into a pure array of 12 components for datastore compatibility.
]]
function DatabaseService.SerializeCFrame(cf: CFrame): {number}
	return {cf:GetComponents()}
end

--[[
	Reconstructs a Roblox CFrame from an array of 12 components.
]]
function DatabaseService.DeserializeCFrame(coords: {number}): CFrame
	if typeof(coords) ~= "table" or #coords < 12 then
		warn("[DatabaseService]: Deserialization encountered malformed coordinates. Falling back to identity CFrame.")
		return CFrame.identity
	end
	return CFrame.new(table.unpack(coords, 1, 12))
end

