--[[
	Authoritatively registers a newly placed object to the player's profile data.
]]
function DatabaseService.AddPlacedObject(player: Player, placementId: string, objectName: string, cf: CFrame): boolean
	local data = DatabaseService.GetProfileData(player)
	if not data then return false end

	data.PlacedObjects[placementId] = {
		ObjectName = objectName,
		CF = DatabaseService.SerializeCFrame(cf)
	}
	return true
end

--[[
	Authoritatively removes a placed object from the player's profile data.
]]
function DatabaseService.RemovePlacedObject(player: Player, placementId: string): boolean
	local data = DatabaseService.GetProfileData(player)
	if not data then return false end

	if data.PlacedObjects[placementId] then
		data.PlacedObjects[placementId] = nil
		return true
	end
	return false
end

--[[
	Authoritatively updates the transform coordinates of an existing placed object.
]]
function DatabaseService.UpdatePlacedObjectCFrame(player: Player, placementId: string, cf: CFrame): boolean
	local data = DatabaseService.GetProfileData(player)
	if not data then return false end

	local objectData = data.PlacedObjects[placementId]
	if objectData then
		objectData.CF = DatabaseService.SerializeCFrame(cf)
		return true
	end
	return false
end

--[[
	Authoritatively adjusts player coins on the server, preventing negative balance overlaps.
	Instantly replicates state updates using Roblox Player Attributes.
]]
function DatabaseService.AdjustCoins(player: Player, amount: number): boolean
	local data = DatabaseService.GetProfileData(player)
	if not data then return false end

	if amount < 0 and math.abs(amount) > data.Coins then
		return false -- Prevent transaction if insufficient balance
	end

	data.Coins += amount
	player:SetAttribute("Coins", data.Coins)
	return true
end

--[[
	Authoritatively awards server-calculated experience and manages dynamic levels.
]]
function DatabaseService.AddExperience(player: Player, amount: number)
	local data = DatabaseService.GetProfileData(player)
	if not data then return end

	data.Experience += amount

	-- Simple progression lookup formula (1000 exp per level)
	local requiredExp = data.Level * 1000
	while data.Experience >= requiredExp do
		data.Experience -= requiredExp
		data.Level += 1
		requiredExp = data.Level * 1000
		player:SetAttribute("Level", data.Level)
		print(`[DatabaseService]: {player.Name} has authoritatively leveled up to Level {data.Level}!`)
	end
end

--[[
	Authoritatively sets employee leveling hierarchies and replicates instantly.
]]
function DatabaseService.SetStaffLevel(player: Player, staffType: string, level: number): boolean
	local data = DatabaseService.GetProfileData(player)
	if not data then return false end

	if data.Staff[staffType] ~= nil then
		data.Staff[staffType] = level
		player:SetAttribute(`Staff_{staffType}`, level)
		return true
	end
	return false
end

-- ============================================================================
-- MASTER SESSION CYCLE INITIALIZERS
-- ============================================================================

local function LoadPlayerProfile(player: Player)
	local sessionTrove = Trove.new()
	ProfileTroves[player] = sessionTrove

	sessionTrove:AttachToInstance(player)

	-- Populate initial attributes state so client starts out completely synchronized
	player:SetAttribute("Coins", DEFAULT_PROFILE_TEMPLATE.Coins)
	player:SetAttribute("Level", DEFAULT_PROFILE_TEMPLATE.Level)
	for staffName, level in pairs(DEFAULT_PROFILE_TEMPLATE.Staff) do
		player:SetAttribute(`Staff_{staffName}`, level)
	end

	if not ProfileStore then
		warn(`[DatabaseService]: ProfileStore is missing from environment! Simulating mock session for {player.Name}.`)

		task.wait(0.5)
		if not Players:FindFirstChild(player.Name) then 
			sessionTrove:Clean()
			ProfileTroves[player] = nil
			return 
		end

		local mockProfile = {
			Data = table.clone(DEFAULT_PROFILE_TEMPLATE),
			Reconcile = function() end,
			ListenToRelease = function(self, cb) end,
			Release = function() end
		}

		ActiveProfiles[player] = mockProfile

		-- Sync actual simulated initial states to attributes
		player:SetAttribute("Coins", mockProfile.Data.Coins)
		player:SetAttribute("Level", mockProfile.Data.Level)
		for staffName, level in pairs(mockProfile.Data.Staff) do
			player:SetAttribute(`Staff_{staffName}`, level)
		end

		-- Handle simulation offline progression immediately on load
		ProcessOfflineEarnings(player, mockProfile.Data)

		-- Broadcast handshake event to all listening client/server ecosystems asynchronously
		profileLoadedSignal:Fire(player, mockProfile.Data)
		return
	end

	local profileKey = `Player_{player.UserId}`
	local store = DatabaseService._Store

	task.spawn(function()
		local profile = store:StartProfileAsync(profileKey)

		if not profile then
			player:Kick("Failed to load your profile session safely. Please re-join!")
			sessionTrove:Clean()
			ProfileTroves[player] = nil
			return
		end

		if not player:IsDescendantOf(Players) then
			profile:Release()
			sessionTrove:Clean()
			ProfileTroves[player] = nil
			return
		end

		profile:Reconcile()

		profile:ListenToRelease(function()
			DatabaseService.UnloadPlayerProfile(player)
			player:Kick("Your data profile was loaded on another server. Session closed.")
		end)

		ActiveProfiles[player] = profile

		-- Re-sync actual reconciled profile data to attributes upon successful handshake load
		player:SetAttribute("Coins", profile.Data.Coins)
		player:SetAttribute("Level", profile.Data.Level)
		for staffName, level in pairs(profile.Data.Staff) do
			player:SetAttribute(`Staff_{staffName}`, level)
		end

		-- Process high-security offline progress calculations
		ProcessOfflineEarnings(player, profile.Data)

		-- Broadcast authoritative data handshake across decoupled systems
		profileLoadedSignal:Fire(player, profile.Data)
		print(`[DatabaseService]: Successfully loaded and bound profile session for {player.Name}!`)
	end)
end

--[[
	Gracefully handles pre-unload mutations, runs security validation right before saving,
	releases plot claims, cleans up the master session Trove, and releases the database lock.
]]
function DatabaseService.UnloadPlayerProfile(player: Player)
	local profile = ActiveProfiles[player]

	-- Step 4.2: Safe Auto-Save Re-Validation (Pre-Save Handshake Cycle)
	-- 1. Fire the unload signal BEFORE tearing down objects.
	-- This lets other systems perform final flushes (e.g. converting running data back into profile.Data)
	if profile then
		profileUnloadingSignal:Fire(player, profile.Data)

		-- Securely write UTC leaving timestamp before saving to capture offline intervals
		profile.Data.LastLeaveTimestamp = os.time()
	end

	-- 2. Validate all placed objects one final time before the data is serialized and flushed to the cloud.
	-- This catches any anomalies or glitch manipulations that happened during gameplay!
	if profile then
		local claimedPlotName = player:GetAttribute("ClaimedPlot")
		if claimedPlotName then
			local plotModel = workspace:FindFirstChild(claimedPlotName)
			local plotBase = plotModel and (plotModel:FindFirstChild("Base") or plotModel:FindFirstChildOfClass("Part"))
			if plotBase and plotBase:IsA("BasePart") then
				-- Validate the profile state and authoritatively prune any out-of-bounds configurations
				DatabaseService.GetAndValidatePlacedObjects(player, plotBase)
			end
		end
	end

	-- Step 4.3: Graceful Plot Attribute Resetting
	-- Clear plot attributes instantly so other players can claim it immediately without waiting for datastore flushes to finish
	local claimedPlotName = player:GetAttribute("ClaimedPlot")
	if claimedPlotName then
		local plot = workspace:FindFirstChild(claimedPlotName)
		if plot then
			plot:SetAttribute("Owner", nil)
			plot:SetAttribute("OwnerName", nil)
			print(`[DatabaseService]: Authoritatively reset plot attributes for '{claimedPlotName}' and unassigned ownership of {player.Name}.`)
		end
	end

	-- Step 4.1: Track the Release State via Trove (Zero-Leak Atomic Instance Sweep)
	-- Wipe out every instance registered to the player session (physical racks, active workforce NPCs, listeners, loops)
	local sessionTrove = ProfileTroves[player]
	if sessionTrove then
		sessionTrove:Clean()
		ProfileTroves[player] = nil
		print(`[DatabaseService]: Active Trove session flushed for {player.Name}.`)
	end

	-- Step E: Release and close profile session lock
	if profile then
		profile:Release()
		ActiveProfiles[player] = nil
	end
end

function DatabaseService.Initialize()
	if DatabaseService._Initialized then return end

	if ProfileStore then
		DatabaseService._Store = ProfileStore.New("PlayerDataStore_v1", DEFAULT_PROFILE_TEMPLATE)
		print("[DatabaseService]: ProfileStore engine initialized successfully.")
	else
		warn("[DatabaseService]: Initialized database in simulated MOCK environment.")
	end

	-- Register authoritative upgrade network hooks and admin listeners
	RegisterCheckoutHandlers()
	RegisterAdminHooks()

	for _, player in ipairs(Players:GetPlayers()) do
		task.spawn(LoadPlayerProfile, player)
	end

	Players.PlayerAdded:Connect(LoadPlayerProfile)

	Players.PlayerRemoving:Connect(function(player)
		DatabaseService.UnloadPlayerProfile(player)
	end)

	DatabaseService._Initialized = true
	print("[DatabaseService INITIALIZED] Elite transaction engines, offline calculus, and secure debugging hooks are fully active.")
end

return DatabaseService
