--[[
	Dynamic safe network folder/remote resolver.
]]
local function GetRemote(name: string, className: "RemoteEvent" | "UnreliableRemoteEvent"): any
	local eventsFolder = RepS:FindFirstChild("Events")
	if not eventsFolder then
		local newFolder = Instance.new("Folder")
		newFolder.Name = "Events"
		newFolder.Parent = RepS
		eventsFolder = newFolder
	end

	local remotesFolder = eventsFolder:FindFirstChild("Remotes")
	if not remotesFolder then
		local newFolder = Instance.new("Folder")
		newFolder.Name = "Remotes"
		newFolder.Parent = eventsFolder
		remotesFolder = newFolder
	end

	local targetRemote = remotesFolder:FindFirstChild(name)
	if not targetRemote then
		local newRemote = Instance.new(className)
		newRemote.Name = name
		newRemote.Parent = remotesFolder
		targetRemote = newRemote
	end

	return targetRemote
end

-- ============================================================================
-- STEP 5.1: ATOMIC TRANSACTION VALIDATION ENGINE
-- ============================================================================

--[[
	Runs user mutations inside an isolated structural sandbox. If any error occur
	or the transaction is marked invalid, the data reverts completely to standard pre-states.
]]
function DatabaseService.RunAtomicTransaction(player: Player, transactionCallback: (profileData: ProfileData) -> (boolean, string?)): (boolean, string?)
	local profile = ActiveProfiles[player]
	if not profile then 
		return false, "No active profile session found."
	end

	-- Create an airtight sandbox state checkpoint
	local preTransactionCheckpoint = DeepCopyTable(profile.Data)

	-- Execute mutations inside a protected callback call
	local runSuccess, callbackSuccess, feedbackMessage = pcall(function()
		return transactionCallback(profile.Data)
	end)

	if runSuccess and callbackSuccess then
		-- Apply state updates authoritatively across attributes
		player:SetAttribute("Coins", profile.Data.Coins)
		player:SetAttribute("Level", profile.Data.Level)
		for staffName, level in pairs(profile.Data.Staff) do
			player:SetAttribute(`Staff_{staffName}`, level)
		end
		return true, feedbackMessage or "Atomic transaction completed successfully."
	else
		-- Rollback state completely to pre-transaction values to prevent state fragmentation
		profile.Data = preTransactionCheckpoint
		local errText = if not runSuccess then tostring(callbackSuccess) else (feedbackMessage or "Unknown Transaction Error")
		warn(`[DatabaseService Atomic Transaction Rollback]: Failsafe triggered on {player.Name}! State rolled back. Reason: {errText}`)
		return false, `Transaction Failed: {errText}`
	end
end

-- ============================================================================
-- STEP 5.2: SECURE OFFLINE PROGRESSION & TIME-SKIP ENVIRONMENT
-- ============================================================================

--[[
	Processes offline progression mechanics authoritatively.
]]
local function ProcessOfflineEarnings(player: Player, data: ProfileData, customElapsedOverride: number?)
	local lastLeave = data.LastLeaveTimestamp
	local now = os.time()

	-- If it's a first-time play or invalid clock stamp, skip calculations
	if lastLeave <= 0 then 
		data.LastLeaveTimestamp = now
		return 
	end

	local secondsElapsed = customElapsedOverride or math.max(0, now - lastLeave)
	if secondsElapsed < 60 then
		-- Sub 1-minute sessions do not trigger offline progression loops
		data.LastLeaveTimestamp = now
		return
	end

	-- 12 hours hard limit cap to avoid hyperinflation
	local maxAllowedOfflineSeconds = 12 * 3600
	local evaluatedSeconds = math.min(secondsElapsed, maxAllowedOfflineSeconds)

	-- Income Multipliers Curve (Coins generated per second offline based on employee levels)
	-- Cashiers generate passive baseline cash, Stockers and Janitors add minor cumulative multipliers
	local earningsPerSecond = (data.Staff.Cashier * 0.5) + (data.Staff.Stockman * 0.3) + (data.Staff.Janitor * 0.2)
	local rawEarnings = math.floor(evaluatedSeconds * earningsPerSecond)

	if rawEarnings > 0 then
		data.Coins += rawEarnings
		player:SetAttribute("Coins", data.Coins)
		offlineEarningsProcessedSignal:Fire(player, rawEarnings, evaluatedSeconds)
		print(`[DatabaseService Passive Engine]: Processed {player.Name}'s offline progress! Secured {rawEarnings} coins for {math.round(evaluatedSeconds / 60)} minutes offline.`)
	end

	data.LastLeaveTimestamp = now
end

--[[
	Binds high-security checkout transactions for employee unlocks and upgrades.
	Utilizes Step 5.1 Atomic Transactions to ensure zero-loss mutations.
]]
local function RegisterCheckoutHandlers()
	local purchaseStaffRemote = GetRemote("PurchaseStaff", "RemoteEvent") :: RemoteEvent

	purchaseStaffRemote.OnServerEvent:Connect(function(player: Player, staffType: any)
		if typeof(staffType) ~= "string" then
			warn(`[DatabaseService Security]: Blocked malformed upgrade request payload from {player.Name}`)
			return
		end

		-- Wrap purchase checkout securely in our safe atomic transactional wrapper
		local txSuccess, txError = DatabaseService.RunAtomicTransaction(player, function(profileData)
			local currentLevel = profileData.Staff[staffType]
			if not currentLevel then
				error(`Staff type '{staffType}' does not exist inside active schema config.`)
			end

			local upgradesList = STAFF_UPGRADE_MATRIX[staffType]
			if not upgradesList then
				error(`Missing pricing details for staff type '{staffType}'`)
			end

			local nextLevel = currentLevel + 1
			local cost = upgradesList[nextLevel]

			if not cost then
				error(`Staff type '{staffType}' is already at the maximum level cap.`)
			end

			if profileData.Coins < cost then
				error(`Insufficient coins. (Required: {cost}, Balance: {profileData.Coins})`)
			end

			-- Perform safe mutations within sandbox
			profileData.Coins -= cost
			profileData.Staff[staffType] = nextLevel

			-- Safe transaction completed successfully
			return true
		end)

		if txSuccess then
			-- Fire dynamic LemonSignal downstream to let workforce AI handle character spawns
			local currentLevel = DatabaseService.GetProfileData(player).Staff[staffType]
			staffUpgradedSignal:Fire(player, staffType, currentLevel)
		else
			warn(`[DatabaseService Checkout Failed]: {txError}`)
		end
	end)
end

