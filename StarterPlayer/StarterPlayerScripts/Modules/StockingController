local Players = game:GetService("Players") 
local CollectionS = game:GetService("CollectionService") 
local RepS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer 
local shared = RepS:WaitForChild("Shared") 
local modules = shared:WaitForChild("Modules") 
local libraries = RepS:WaitForChild("Libraries")

local ShopConfig = require(modules:WaitForChild("ShopConfig")) 
local Trove = require(libraries:WaitForChild("Trove"))

local StockingController = {} 
local carryTrove = Trove.new() 
local rackTroves = {} 
local activeEquippedCrate: Tool? = nil

-- Checks if a tool is a valid crate and returns parsed name data 
local function IsCrateTool(tool: Tool): any? 
	return ShopConfig.ParseCrateName(tool.Name) 
end

-- Safely calculates requirements and updates local rendering state
local function UpdateRackPrompt(rack: Model) 
	local prompt = rack:FindFirstChildOfClass("ProximityPrompt") :: ProximityPrompt? 
	if not prompt then return end

	local isHoldingCrate = (activeEquippedCrate ~= nil)
	local crateStyle = nil

	if activeEquippedCrate then
		local parsed = IsCrateTool(activeEquippedCrate)
		if parsed then 
			crateStyle = parsed.Style 
		end
	end

	local targetState = false

	if isHoldingCrate and crateStyle then
		local rackType = rack:GetAttribute("RackType") :: string?
		local maxSlots = rack:GetAttribute("MaxSlots") or 4
		local occupiedSlots = rack:GetAttribute("OccupiedSlots") or 0
		local placedBy = rack:GetAttribute("PlacedBy") :: number?

		local isOwner = (placedBy == player.UserId)
		local hasSpace = (occupiedSlots < maxSlots)

		-- FIXED: Explicitly safe lookup through the dictionary fields
		local hasCompatibleItem = false
		if rackType and ShopConfig.Items then
			for _, itemData in pairs(ShopConfig.Items) do
				if typeof(itemData) == "table" and itemData.Theme == crateStyle and itemData.Category == rackType then
					hasCompatibleItem = true
					break
				end
			end
		end

		if isOwner and hasSpace and hasCompatibleItem then
			targetState = true
		else
			-- Diagnostic fallback: helpful console warn if you're holding a crate but it won't let you stock
			if isHoldingCrate and not targetState then
				warn(string.format("[Stocking Debug] Clamped Rack: Owner=%s, Space=%s, Compatible=%s (Crate Style: '%s', Rack Type: '%s')", 
					tostring(isOwner), tostring(hasSpace), tostring(hasCompatibleItem), tostring(crateStyle), tostring(rackType)))
			end
		end
	end

	-- Enforce strict target mutations to prevent frame-fighting desyncs
	if prompt.Enabled ~= targetState then
		prompt.Enabled = targetState
	end
end

local function UpdateLocalPrompts() 
	for _, rack in ipairs(CollectionS:GetTagged("RetailRack")) do 
		if rack:IsA("Model") then 
			UpdateRackPrompt(rack) 
		end 
	end 
end

local function MonitorRack(rack: Instance) 
	if not rack:IsA("Model") then return end 
	if rackTroves[rack] then return end

	local trove = Trove.new()
	rackTroves[rack] = trove

	local function triggerUpdate()
		UpdateRackPrompt(rack)
	end

	trove:Connect(rack:GetAttributeChangedSignal("OccupiedSlots"), triggerUpdate)
	trove:Connect(rack:GetAttributeChangedSignal("PlacedBy"), triggerUpdate)
	trove:Connect(rack:GetAttributeChangedSignal("MaxSlots"), triggerUpdate)
	trove:Connect(rack:GetAttributeChangedSignal("RackType"), triggerUpdate)

	trove:Connect(rack.ChildAdded, function(child)
		if child:IsA("ProximityPrompt") then triggerUpdate() end
	end)

	triggerUpdate()
end

local function UnmonitorRack(rack: Instance) 
	local trove = rackTroves[rack] 
	if trove then 
		trove:Destroy() 
		rackTroves[rack] = nil 
	end 
end

local function ScanCharacterForTools(character: Model)
	local currentTool = character:FindFirstChildOfClass("Tool")
	if currentTool and IsCrateTool(currentTool) then
		activeEquippedCrate = currentTool
	else
		activeEquippedCrate = nil
	end
	UpdateLocalPrompts()
end

local function HandleCharacter(character: Model) 
	carryTrove:Clean()

	ScanCharacterForTools(character)

	carryTrove:Connect(character.ChildAdded, function(child: Instance)
		if child:IsA("Tool") and IsCrateTool(child) then
			activeEquippedCrate = child
			UpdateLocalPrompts()
		end
	end)

	carryTrove:Connect(character.ChildRemoved, function(child: Instance)
		if child:IsA("Tool") and child == activeEquippedCrate then
			task.defer(function()
				local stillEquipped = character:FindFirstChildOfClass("Tool")
				if not stillEquipped or not IsCrateTool(stillEquipped) then
					activeEquippedCrate = nil
					UpdateLocalPrompts()
				end
			end)
		end
	end)
end

function StockingController.Initialize() 
	if player.Character then HandleCharacter(player.Character) end
	player.CharacterAdded:Connect(HandleCharacter)

	for _, rack in ipairs(CollectionS:GetTagged("RetailRack")) do
		MonitorRack(rack)
	end

	CollectionS:GetInstanceAddedSignal("RetailRack"):Connect(MonitorRack)
	CollectionS:GetInstanceRemovedSignal("RetailRack"):Connect(UnmonitorRack)

	print("[StockingController INITIALIZED] Fixed Loop Safe Prompt Logic Live.")
end

return StockingController
